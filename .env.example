# App
APP_ENV=development
SECRET_KEY=change-me-in-production
API_BASE_URL=https://medianetpay.ec

# Base de datos
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medianetpay

# Redis
REDIS_URL=redis://localhost:6379

# MediaNet — conector
# En desarrollo apunta al mock server local
# En producción apunta al API real de MediaNet
MEDIANET_API_URL=http://localhost:9000
MEDIANET_API_KEY=test-key
MEDIANET_API_SECRET=test-secret
MEDIANET_TIMEOUT_SECONDS=10
MEDIANET_MAX_RETRIES=3

# Anthropic (analytics LLM — Fase 6)
ANTHROPIC_API_KEY=

# Sentry (monitoreo — Fase 5)
SENTRY_DSN=
