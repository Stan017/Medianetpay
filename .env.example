# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
SECRET_KEY=change-me-in-production          # openssl rand -hex 32
API_BASE_URL=http://localhost:8000
PORTAL_BASE_URL=http://localhost:3000        # URL of the Next.js merchant portal

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:    postgresql+asyncpg://postgres:password@localhost:5432/medianetpay
# Supabase: postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medianetpay

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Leave empty to skip — rate limiting falls back to per-process memory
# Upstash: rediss://default:[password]@[host].upstash.io:6379
REDIS_URL=

# ─── MediaNet connector ───────────────────────────────────────────────────────
# Development: points to the local mock server (mock_medianet/)
# Production:  real MediaNet WebCheckout API endpoint
MEDIANET_API_URL=http://localhost:9000
MEDIANET_API_KEY=test-key
MEDIANET_API_USERNAME=test_merchant
MEDIANET_API_SECRET=test-secret
MEDIANET_TIMEOUT_SECONDS=15
MEDIANET_MAX_RETRIES=2

# ─── Google OAuth (mobile app — optional) ────────────────────────────────────
# Web Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# ─── Anthropic (LLM analytics + Annie chatbot — optional) ────────────────────
ANTHROPIC_API_KEY=

# ─── Sentry (error tracking — optional) ──────────────────────────────────────
SENTRY_DSN=
