{# MedianetPay - Boton de pago en el checkout de OpenCart #}
<div id="medianetpay-payment">
    <p style="margin-bottom: 16px; color: #374151; font-size: 14px;">
        Seras redirigido a la pagina segura de MedianetPay para completar tu pago con tarjeta.
    </p>
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
        <img src="catalog/view/theme/default/image/payment/medianetpay_logo.png" alt="MedianetPay" style="height: 28px;">
        <span style="font-size: 12px; color: #6b7280;">Pago seguro con certificacion PCI DSS</span>
    </div>
    <div id="payment-method-error" style="display:none; color:#dc2626; background:#fee2e2; padding:10px 14px; border-radius:8px; margin-bottom:12px; font-size:13px;"></div>
    <input type="button" value="{{ button_confirm }}" id="button-confirm"
           style="background:#003865; color:#fff; border:none; padding:12px 32px; border-radius:8px; font-size:15px; font-weight:600; cursor:pointer; width:100%;"
           data-loading-text="Procesando..." />
</div>

<script>
    $('#button-confirm').on('click', function() {
        var btn = $(this);
        btn.prop('disabled', true).val(btn.data('loadingText'));
        $('#payment-method-error').hide();

        $.ajax({
            url: '{{ action }}',
            type: 'post',
            dataType: 'json',
            data: 'order_id={{ order_id }}',
            success: function(json) {
                if (json.redirect) {
                    location = json.redirect;
                }
                if (json.error) {
                    $('#payment-method-error').text(json.error).show();
                    btn.prop('disabled', false).val('{{ button_confirm }}');
                }
            },
            error: function() {
                $('#payment-method-error').text('Error de conexion. Intenta nuevamente.').show();
                btn.prop('disabled', false).val('{{ button_confirm }}');
            }
        });
    });
</script>
